{
    "outputDirectory": "site/public",
    "buildCommand": "bash site/build.sh",
    "headers": [
        {
            "source": "/embed/(.*)",
            "headers": [
                { "key": "X-Frame-Options", "value": "ALLOWALL" },
                { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
            ]
        },
        {
            "source": "/flipbooks/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/static/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ]
}
